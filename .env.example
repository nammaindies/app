# Copy to .env and fill in real values before running docker-compose.prod.yml.

# Domain Caddy will auto-provision TLS for. For local testing without a
# real domain, set APP_DOMAIN=:80 to serve plain HTTP on port 80.
APP_DOMAIN=app.example.org

# Postgres (used by the bundled `db` service; see note below for RDS).
POSTGRES_PASSWORD=change-me

# App secrets.
PHONE_HASH_SECRET=change-me
SESSION_SECRET=change-me
MAGIC_LINK_SECRET=change-me

# S3-compatible object storage for sighting photos.
# S3_ENDPOINT for real AWS S3 is the regional endpoint below; the app's
# default of http://localhost:9000 is only for local MinIO dev.
S3_ENDPOINT=https://s3.ap-south-1.amazonaws.com
S3_BUCKET=nammaindies-photos-prod
S3_ACCESS_KEY=...
S3_SECRET_KEY=...
S3_REGION=ap-south-1

# Managed-DB alternative (RDS): set these two and drop the `db` service from
# docker-compose.prod.yml. When set here they take no effect on their own --
# docker-compose.prod.yml currently overrides DATABASE_URL/DATABASE_URL_SYNC
# to point at the bundled `db` service; see the comment there for how to
# switch to RDS.
# DATABASE_URL=postgresql://user:pass@your-rds-host:5432/indiedex
# DATABASE_URL_SYNC=postgresql+psycopg://user:pass@your-rds-host:5432/indiedex
